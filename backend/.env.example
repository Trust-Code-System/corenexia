# Corenexia backend configuration. Copy to `.env` and fill in.

# --- LLM provider ---------------------------------------------------------
# Which provider drives the orchestrator: "anthropic" (default) or "gemini" (stub).
LLM_PROVIDER=anthropic

# Anthropic (default). Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=2

# Gemini (provider is stubbed in Milestone 1; key reserved for later).
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-pro

# --- Sandbox (Docker) -----------------------------------------------------
SANDBOX_IMAGE=corenexia-sandbox
SANDBOX_MEMORY=512m
SANDBOX_CPUS=1.0
SANDBOX_PIDS_LIMIT=128
SANDBOX_TIMEOUT_SECONDS=30
# Max simultaneous sandbox containers (protects host resources under load).
SANDBOX_MAX_CONCURRENCY=4
# Isolation backend: docker (default; Windows/macOS/Linux) | gvisor (runsc; Linux) | e2b (microVM).
SANDBOX_RUNTIME=docker
# seccomp: "default" (Docker's filter), "unconfined" (not recommended), or a path to a profile.
SANDBOX_SECCOMP_PROFILE=default

# --- Orchestrator ---------------------------------------------------------
# Hard cap on reasoning iterations to prevent runaway loops.
MAX_ITERATIONS=6
LLM_MAX_TOKENS=8000
# Persistent run/audit store (SQLite).
RUNS_DB=corenexia_runs.db

# --- Gateway (Milestone 4) ------------------------------------------------
# When true, /v1/* requires 'Authorization: Bearer <api_key>'. Leave false for local dev.
AUTH_ENABLED=false
# Guards /admin/keys (header: X-Admin-Token). Set a long random value to enable key management.
ADMIN_TOKEN=
# Per-key requests allowed per rolling minute (0 disables rate limiting).
RATE_LIMIT_PER_MINUTE=60
# SQLite file holding API keys + usage counters.
API_KEYS_DB=corenexia_keys.db

# --- Hardening (Milestone 5) ----------------------------------------------
# Comma-separated browser origins allowed by CORS (the God View frontend).
ALLOWED_ORIGINS=http://localhost:3000

# --- Observability (Initiative B): OpenTelemetry GenAI tracing ------------
# Turn on OTel spans for every run/LLM-turn/tool-execution. Off by default.
OTEL_ENABLED=false
OTEL_SERVICE_NAME=corenexia
# Debug: print spans to stdout instead of exporting (no OTLP endpoint needed).
OTEL_CONSOLE_EXPORT=false
# OTLP destination (standard OTel env vars; consumed by the exporter). Examples:
#   Phoenix (local):  OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:6006/v1/traces
#   Langfuse (cloud): OTEL_EXPORTER_OTLP_ENDPOINT=https://cloud.langfuse.com/api/public/otel
#                     OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic%20<base64 pk:sk>
# See OBSERVABILITY.md for the full setup.
# OTEL_EXPORTER_OTLP_ENDPOINT=
# OTEL_EXPORTER_OTLP_HEADERS=
